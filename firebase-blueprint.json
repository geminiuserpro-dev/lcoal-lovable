{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A user's project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "repoUrl": { "type": "string" },
        "storagePath": { "type": "string", "description": "Path to the project files in Firebase Storage" },
        "lastModified": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "lastModified", "createdAt"]
    },
    "ProjectFile": {
      "title": "ProjectFile",
      "description": "A file within a project",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "content": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["path", "content", "ownerId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "role", "projectId", "userId", "timestamp"]
    },
    "SandboxState": {
      "title": "SandboxState",
      "description": "The current state of a user's sandbox",
      "type": "object",
      "properties": {
        "sandboxId": { "type": "string" },
        "workDir": { "type": "string" },
        "repoUrl": { "type": "string" },
        "projectId": { "type": "string" },
        "previewActive": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["workDir", "previewActive", "lastUpdated"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "User projects"
    },
    "projects/{projectId}/files/{fileId}": {
      "schema": { "$ref": "#/entities/ProjectFile" },
      "description": "Files belonging to a project"
    },
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat messages"
    },
    "sandbox_states/{userId}": {
      "schema": { "$ref": "#/entities/SandboxState" },
      "description": "User sandbox states"
    }
  }
}
